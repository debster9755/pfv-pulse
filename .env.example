# ─────────────────────────────────────────────
# PFV-Pulse Environment Variables
# Copy this file to .env.local for local development
# Add all variables to Vercel project settings for deployment
# ─────────────────────────────────────────────

# ── PostgreSQL (Neon) ─────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
# Use the "pooled" connection string for serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── Redis (Upstash) ───────────────────────────
# Get from: https://console.upstash.com → your Redis database → REST URL
# Use the redis:// connection string (not the REST URL)
UPSTASH_REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# ── SerpApi ──────────────────────────────────
# Get from: https://serpapi.com/dashboard
# Used for: Google Shopping price aggregation (high/avg/low retail prices)
SERPAPI_KEY="your_serpapi_key_here"

# ── Keepa API ─────────────────────────────────
# Get from: https://keepa.com/#!api
# Used for: 30-day Amazon price history by ASIN
KEEPA_API_KEY="your_keepa_api_key_here"

# ── Best Buy Developer API ────────────────────
# Get from: https://bestbuy.com/developer/documentation
# Used for: Base MSRP, stock status, product catalog search
BESTBUY_API_KEY="your_bestbuy_api_key_here"

# ── Scraper Service ───────────────────────────
# URL of the deployed Playwright scraper service (Option B — separate service)
# Local development: http://localhost:3001
# Production: your Railway / Fly.io / Render deployment URL
SCRAPER_SERVICE_URL="http://localhost:3001"
